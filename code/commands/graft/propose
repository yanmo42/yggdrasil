#!/bin/sh
# ygg v1: graft propose
# Propose a graft (additive change)

set -e

USAGE="Usage: ygg graft propose <description>"
if [ "$#" -lt 1 ]; then
  echo "$USAGE"
  exit 1
fi

DESC="$1"

RUN_DIR="$HOME/ygg/state/runtime/ravens"
GRAFT_DIR="$RUN_DIR/grafts"
mkdir -p "$GRAFT_DIR"

GRAFT_ID="GRAFT-$(date +'%Y-%m-%d-%H%M%S-$(head -c4 /dev/urandom | od -An -tx1 | tr -d ' \n')')"
TS="$(date +'%Y-%m-%dT%H:%M:%S%z')"

cat > "$GRAFT_DIR/$GRAFT_ID.md" <<EOF
# Graft Proposal: $GRAFT_ID

**ID**: $GRAFT_ID  
**Timestamp**: $TS  
**Type**: Graft (additive)

## Description
$DESC

## Attachment Point
[TBD: specify where in Ygg this should attach]

## Rationale
[TBD: why now?]

## Expected Benefit
[TBD: what does this enable?]

## Failure Conditions
[TBD: what could go wrong?]

## Governance Path
[TBD: how does this get approved and merged?]
EOF

echo "Graft proposal created: $GRAFT_DIR/$GRAFT_ID.md"
echo "Next steps: fill in attachment point, rationale, etc., then request spine adjudication."
