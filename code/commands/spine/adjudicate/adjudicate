#!/bin/sh
# ygg v1: Spine adjudication command
# Adjudicate a flight's disposition

set -e

USAGE="Usage: ygg spine adjudicate <flight-id> <disposition>"
if [ "$#" -ne 2 ]; then
  echo "$USAGE"
  exit 1
fi

FLIGHT_ID="$1"
DISPOSITION="$2"

# Validate flight exists
RUN_DIR="$HOME/ygg/state/runtime/ravens"
FLIGHT_DIR="$RUN_DIR/flights/$FLIGHT_ID"
if [ ! -d "$FLIGHT_DIR" ]; then
  echo "Flight not found: $FLIGHT_ID"
  exit 1
fi

# Update flight status
cat > "$FLIGHT_DIR/status.json" <<EOF
{
  "status": "$DISPOSITION",
  "adjudicated_at": "$(date +'%Y-%m-%dT%H:%M:%S%z')"
}
EOF

# Log adjudication
cat >> "$RUN_DIR/logs/ravens.jsonl" <<EOF
{"event":"adjudicated","flight_id":"$FLIGHT_ID","disposition":"$DISPOSITION","timestamp":"$(date +'%Y-%m-%dT%H:%M:%S%z')"}
EOF

echo "Flight adjudicated: $FLIGHT_ID -> $DISPOSITION"
