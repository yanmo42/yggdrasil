#!/bin/sh
# ygg v1: Muninn inward transform
# Return a flight's findings to spine

set -e

USAGE="Usage: ygg raven return <flight-id> [--evidence <file>] [--summary <text>] [--discrepancies <text>]"
if [ "$#" -lt 1 ]; then
  echo "$USAGE"
  exit 1
fi

FLIGHT_ID="$1"
shift

EVIDENCE=""
SUMMARY=""
DISCREPANCIES=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --evidence) EVIDENCE="$2"; shift 2 ;;
    --summary) SUMMARY="$2"; shift 2 ;;
    --discrepancies) DISCREPANCIES="$2"; shift 2 ;;
    *) echo "Unknown param: $1"; exit 1 ;;
  esac
done

# Validate flight exists
RUN_DIR="$HOME/ygg/state/runtime/ravens"
FLIGHT_DIR="$RUN_DIR/flights/$FLIGHT_ID"
if [ ! -d "$FLIGHT_DIR" ]; then
  echo "Flight not found: $FLIGHT_ID"
  exit 1
fi

# Muninn return event
TS="$(date +'%Y-%m-%dT%H:%M:%S%z')"
cat >> "$RUN_DIR/logs/ravens.jsonl" <<EOF
{"event":"return","flight_id":"$FLIGHT_ID","actor":"Muninn","timestamp":"$TS","evidence_refs":${EVIDENCE:-"null"},"summary":${SUMMARY:-"null"},"discrepancies":${DISCREPANCIES:-"null"}}
EOF

# Create return artifact
RETURN_DIR="$RUN_DIR/returns"
mkdir -p "$RETURN_DIR"
RETURN_FILE="$RETURN_DIR/$FLIGHT_ID.md"
cat > "$RETURN_FILE" <<EOF
# Return: $FLIGHT_ID

**Flight**: $FLIGHT_ID  
**Returned by**: Muninn  
**Timestamp**: $TS

## Purpose
${SUMMARY:-"No summary provided"}

## Evidence References
${EVIDENCE:-"No evidence provided"}

## Summary
${SUMMARY:-"No summary provided"}

## Discrepancies
${DISCREPANCIES:-"No discrepancies noted"}

## Return Class
${EVIDENCE:+✓ Evidence-backed}  ${SUMMARY:+✓ Summarized}  ${DISCREPANCIES:+✓ Discrepancy-annotated}
EOF

echo "Return processed: $RETURN_FILE"
echo "Spine adjudication pending: $FLIGHT_ID"
