# Copy to a local env file (e.g. ~/.config/ygg/bootstrap-host.env), fill values, then run:
#   set -a; source ~/.config/ygg/bootstrap-host.env; set +a
#   ~/ygg/machine/bootstrap-host.sh

# Optional git remotes
SPINE_GIT_URL=
YGG_GIT_URL=
SANDY_CHAOS_GIT_URL=
IANMOOG_SITE_GIT_URL=

# Optional path overrides
# WORKSPACE_ROOT=$HOME/.openclaw/workspace-claw-main
# YGG_ROOT=$HOME/ygg
# PROJECTS_ROOT=$HOME/projects
# SANDY_ROOT=$HOME/projects/sandy-chaos
# SITE_ROOT=$HOME/projects/ianmoog-site

# Optional npm prefix for OpenClaw install fallback
# NPM_PREFIX=$HOME/.npm-global

# Backup defaults (used by state/scripts/spine-backup.sh and machine/install-backup-cron.sh)
# YGG_BACKUP_KEY_FILE=$HOME/.config/ygg/backup.key
# YGG_BACKUP_DIR=$HOME/ygg/state/runtime/backups
# YGG_BACKUP_KEEP=14
# YGG_BACKUP_CRON_SCHEDULE="15 3 * * *"
